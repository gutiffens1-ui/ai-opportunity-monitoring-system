OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Only contacts with this confidence score or higher are saved. Default: 7.
MIN_CONTACT_SCORE=7

# Optional: enable basic public-page reading.
# Keep these false until you are sure the pages are public and allowed to be read.
FETCH_WEBSITES=false
FETCH_PUBLIC_LINKS=false

# Optional: live web search through SerpAPI.
# Sign up separately, then paste your key here if you want live search snippets.
SERPAPI_API_KEY=
